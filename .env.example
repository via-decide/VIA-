# Gemini API configuration (used by src/services/agentService.ts for /post /linkedin /youtube /task)
GEMINI_API_KEY="your_gemini_api_key"

# Telegram Bot token — server-side only, never add VITE_ prefix (must not reach the browser bundle)
# Store in .env.local for local dev; use Firebase Secret Manager for production
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# Optional app URL for deployed environments
APP_URL="http://localhost:3000"

# Firebase web app configuration
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_firebase_app_id"
VITE_FIREBASE_MEASUREMENT_ID="your_measurement_id"
VITE_FIREBASE_DATABASE_ID="(default)"
