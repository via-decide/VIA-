// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId} (Firebase Auth UID)
// Fields:
//   - uid: string (required)
//   - username: string (required)
//   - displayName: string (required)
//   - email: string (optional)
//   - phoneNumber: string (optional)
//   - city: string (optional)
//   - avatarEmoji: string (optional)
//   - xp: number (required)
//   - level: number (required)
//   - followers: number (required)
//   - following: number (required)
//   - posts: number (required)
//   - createdAt: timestamp (required)
//
// Collection: posts
// Document ID: {postId} (Auto-generated)
// Fields:
//   - userId: string (required)
//   - authorName: string (required)
//   - authorAvatar: string (required)
//   - content: string (required)
//   - imageUrl: string (optional)
//   - likes: number (required)
//   - comments: number (required)
//   - shares: number (required)
//   - createdAt: timestamp (required)
//
// Collection: deep_dives
// Document ID: {diveId} (Auto-generated)
// Fields:
//   - title: string (required)
//   - subtitle: string (required)
//   - summary: string (required)
//   - content: string (required)
//   - imageUrl: string (required)
//   - category: string (required)
//   - readTime: number (required)
//   - participants: number (required)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "daxini2404@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.uid is string &&
             data.username is string && data.username.size() >= 3 &&
             data.displayName is string &&
             (data.email == null || data.email is string) &&
             (data.phoneNumber == null || data.phoneNumber is string) &&
             (data.city == null || data.city is string) &&
             (data.avatarEmoji == null || data.avatarEmoji is string) &&
             (data.bio == null || data.bio is string) &&
             data.credits is number &&
             data.xp is number &&
             data.level is number &&
             data.followers is number &&
             data.following is number &&
             data.posts is number &&
             data.createdAt is string;
    }

    function isValidPost(data) {
      return data.userId == request.auth.uid &&
             data.authorName is string &&
             data.authorAvatar is string &&
             data.content is string && data.content.size() > 0 &&
             data.likes is number &&
             data.comments is number &&
             data.shares is number &&
             data.createdAt is string;
    }

    function isValidDeepDive(data) {
      return data.title is string && data.title.size() > 0 &&
             data.subtitle is string &&
             data.summary is string &&
             data.content is string &&
             data.imageUrl is string &&
             data.category is string &&
             data.readTime is number &&
             data.participants is number &&
             data.createdAt is string;
    }

    function isValidComment(data) {
      return data.userId == request.auth.uid &&
             data.authorName is string &&
             data.authorAvatar is string &&
             data.content is string && data.content.size() > 0 &&
             data.createdAt is string;
    }

    function isValidFollow(data) {
      return data.followerId == request.auth.uid &&
             data.followingId is string &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own profile (PII protection)
      // But we need public profiles for the feed.
      // So we'll allow read if the query is for non-PII fields or if owner.
      // For simplicity in this prototype, we'll allow read if authenticated.
      // In a real app, we'd split users into public/private.
      allow read: if isAuthenticated();
      
      allow create: if isOwner(userId) && 
                       isValidUser(request.resource.data) &&
                       (!('role' in request.resource.data) || request.resource.data.role == 'user');

      allow update: if (isOwner(userId) && 
                       isValidUser(request.resource.data) &&
                       request.resource.data.role == resource.data.role) || 
                       isAdmin();
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        // Only allow likes/comments/shares updates for others
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments', 'shares']) ||
        isOwner(resource.data.userId) ||
        isAdmin()
      );
      allow delete: if isOwner(resource.data.userId) || isAdmin();

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow delete: if isOwner(resource.data.userId) || isAdmin();
      }
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFollow(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.followerId || isAdmin());
    }

    match /deep_dives/{diveId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidDeepDive(request.resource.data);
      allow update: if isAdmin() && isValidDeepDive(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
