{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/feed",
      "destination": "/viadecide.html"
    },
    {
      "source": "/viadecide",
      "destination": "/viadecide.html"
    },
    {
      "source": "/viadecide/:path*",
      "destination": "/viadecide.html"
    },
    {
      "source": "/tools",
      "destination": "/viadecide.html"
    },
    {
      "source": "/discover",
      "destination": "/viadecide.html"
    },
    {
      "source": "/about",
      "destination": "/viadecide.html"
    },
    {
      "source": "/profile",
      "destination": "/viadecide.html"
    },
    {
      "source": "/agent",
      "destination": "/viadecide.html"
    },
    {
      "source": "/auth",
      "destination": "/viadecide.html"
    },
    {
      "source": "/games",
      "destination": "/viadecide.html"
    },
    {
      "source": "/explore",
      "destination": "/viadecide.html"
    },
    {
      "source": "/deepdives",
      "destination": "/viadecide.html"
    },
    {
      "source": "/deepdives/:path*",
      "destination": "/viadecide.html"
    },
    {
      "source": "/tool",
      "destination": "/viadecide"
    },
    {
      "source": "/tool/:path*",
      "destination": "/viadecide"
    },
    {
      "source": "/((?!api|assets|shared|js|css|orchard|mars|game|_|sw\\.js|manifest\\.json|favicon\\.ico).*)",
      "destination": "/viadecide.html"
    }
  ],
  "redirects": [
    {
      "source": "/creator",
      "destination": "/creator-onboarding.html"
    },
    {
      "source": "/onboarding",
      "destination": "/creator-onboarding.html"
    },
    {
      "source": "/tool-explorer",
      "destination": "/tool-explorer.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
