{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/feed",
      "destination": "/viadecide.html"
    },
    {
      "source": "/viadecide",
      "destination": "/viadecide.html"
    },
    {
      "source": "/viadecide/:path*",
      "destination": "/viadecide.html"
    },
    {
      "source": "/tools",
      "destination": "/viadecide.html"
    },
    {
      "source": "/tools/:path*",
      "destination": "/viadecide.html"
    },
    {
      "source": "/discover",
      "destination": "/viadecide.html"
    },
    {
      "source": "/about",
      "destination": "/viadecide.html"
    },
    {
      "source": "/profile",
      "destination": "/viadecide.html"
    },
    {
      "source": "/agent",
      "destination": "/viadecide.html"
    },
    {
      "source": "/auth",
      "destination": "/viadecide.html"
    },
    {
      "source": "/games",
      "destination": "/viadecide.html"
    },
    {
      "source": "/explore",
      "destination": "/viadecide.html"
    },
    {
      "source": "/deepdives",
      "destination": "/viadecide.html"
    },
    {
      "source": "/deepdives/:path*",
      "destination": "/viadecide.html"
    },
    {
      "source": "/tool",
      "destination": "/viadecide"
    },
    {
      "source": "/tool/:path*",
      "destination": "/viadecide"
    }
  ],
  "redirects": [
    {
      "source": "/creator",
      "destination": "/creator-onboarding.html"
    },
    {
      "source": "/onboarding",
      "destination": "/creator-onboarding.html"
    },
    {
      "source": "/tool-explorer",
      "destination": "/tool-explorer.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}