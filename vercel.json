{
  "version": 2,
  "name": "viadecide",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "shell/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "tools/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "services/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/tool/([a-z0-9\\-]+)",
      "dest": "/shell/index.html",
      "status": 200
    },
    {
      "src": "/(core|games|productivity|education|experiments)",
      "dest": "/shell/index.html",
      "status": 200
    },
    {
      "src": "/search",
      "dest": "/shell/index.html",
      "status": 200
    },
    {
      "src": "/(.*)",
      "dest": "/shell/index.html",
      "status": 200
    }
  ],
  "env": {
    "API_BASE_URL": "https://api.viadecide.com",
    "ANTHROPIC_API_KEY": "@anthropic_api_key",
    "GEMINI_API_KEY": "@gemini_api_key",
    "OPENAI_API_KEY": "@openai_api_key"
  }
}
