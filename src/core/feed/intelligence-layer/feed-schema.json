{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://via-decide.github.io/schemas/feed/post.schema.json",
  "title": "Feed Post",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "content", "origin", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["Decision", "StudyPlan", "ToolOutput", "Insight"]
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body", "sections", "metadata"],
      "properties": {
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["heading", "text"],
            "properties": {
              "heading": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tags", "source"],
          "properties": {
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "source": {
              "type": "string"
            }
          }
        }
      }
    },
    "origin": {
      "type": "string",
      "enum": ["HUMAN_SEEDED", "USER_GENERATED", "AGENT_GENERATED"]
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp in milliseconds"
    }
  }
}
